{
  "name": "ezuwebs-net",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @ezu/web dev",
    "dev:agent": "pnpm --filter @ezu/agent dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm build && node --test \"apps/agent/dist/apps/agent/src/index.test.js\" \"apps/web/dist/apps/web/src/index.test.js\""
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.2"
  }
}
